# Copier ce fichier en .env et adapter les valeurs

# Topic ntfy (installez l'app ntfy sur votre téléphone et abonnez-vous à ce topic)
NTFY_TOPIC=resa-derm-confluent-votre-nom-unique

# Serveur ntfy (laisser par défaut sauf si vous auto-hébergez)
NTFY_SERVER=https://ntfy.sh

# Intervalle entre deux vérifications (minutes)
CHECK_INTERVAL_MINUTES=15

# Nombre de jours à scanner à l'avance
SCAN_DAYS=90

# Port du dashboard local
PORT=8080

# Adresse d'ecoute : 127.0.0.1 (local/SSH tunnel) ou 0.0.0.0 (accessible depuis l'exterieur)
HOST=127.0.0.1

# Supabase (cocon — étape 1)
# Dashboard projet : https://supabase.com/dashboard
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre-cle-publishable-ou-anon

# Clé service_role : UNIQUEMENT sur le VPS (worker), jamais dans le front ni sur GitHub
SUPABASE_SERVICE_ROLE_KEY=

# ID de la watch active (affiché par scripts/migrate-to-supabase.js)
WATCH_ID=

# Email autorisé pour le login cocon (vide = tout email validé par Supabase)
ALLOWED_EMAIL=